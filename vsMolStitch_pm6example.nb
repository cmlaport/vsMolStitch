Cell["\<\
saveITPInfo parses a monomer itp file. It shifts listed serial numbers by the \
offset value and residue numbers by the number of monomers added. Then it \
adds the information to the relevant global lists. (Requires a monomer itp \
file.)\
\>", "CodeText",
 CellChangeTimes->{{3.883746928352172*^9, 3.88374718250908*^9}, {
  3.885385977467841*^9, 3.885385978910289*^9}, {3.885387473317823*^9, 
  3.885387507359085*^9}},ExpressionUUID->"b8fe751d-27d7-4292-97a7-\
d134019156c0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"saveITPInfo", "[", "monitp_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "dn", ",", "atm", ",", "cnstr", ",", "vs", ",", "bond", ",", "ang", ",", 
      "dih", ",", "aShift", ",", "cShift", ",", "vShift", ",", "bShift", ",", 
      "angShift", ",", "dShift"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "atm", ",", "cnstr", ",", "vs", ",", "bond", ",", "ang", ",", "dih"}], 
       "}"}], "=", 
      RowBox[{"getitpInfo", "[", "monitp", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dn", "=", 
      RowBox[{"offset", "[", 
       RowBox[{"[", 
        RowBox[{"-", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"aShift", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "3", "]"}], "]"}], "+", "nMon"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "4", "]"}], "]"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "5", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "6", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "7", "]"}], "]"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "8", "]"}], "]"}]}], "}"}], "&"}], "/@", "atm"}]}], 
     ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "shift", " ", "added", " ", "monomers", " ", "definitions", " ", "by", 
       " ", "offset"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"cShift", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "3", "]"}], "]"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "4", "]"}], "]"}]}], "}"}], "&"}], "/@", "cnstr"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"vShift", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "3", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "4", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "5", "]"}], "]"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "6", "]"}], "]"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "7", "]"}], "]"}]}], "}"}], "&"}], "/@", "vs"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"bShift", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "3", "]"}], "]"}]}], "}"}], "&"}], "/@", "bond"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"angShift", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "3", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "4", "]"}], "]"}]}], "}"}], "&"}], "/@", "ang"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"dShift", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "3", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "4", "]"}], "]"}], "+", "dn"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "5", "]"}], "]"}]}], "}"}], "&"}], "/@", "dih"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"defAtm", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"defAtm", ",", "aShift"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"defCnstr", " ", "=", " ", 
      RowBox[{"Join", "[", 
       RowBox[{"defCnstr", ",", "cShift"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"defVS", " ", "=", " ", 
      RowBox[{"Join", "[", 
       RowBox[{"defVS", ",", "vShift"}], "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"defBond", " ", "=", " ", 
      RowBox[{"Join", "[", 
       RowBox[{"defBond", ",", "bShift"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"defAng", " ", "=", " ", 
      RowBox[{"Join", "[", 
       RowBox[{"defAng", ",", "angShift"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"defDih", " ", "=", " ", 
      RowBox[{"Join", "[", 
       RowBox[{"defDih", ",", "dShift"}], "]"}]}], ";"}]}], "]"}]}]], "Input",\

 CellChangeTimes->{{3.883399788238336*^9, 3.883399806980089*^9}, {
