Cell["\<\
writeITPLines formats the molecule itp file . 
Required inputs : \[OpenCurlyDoubleQuote]filename\[CloseCurlyDoubleQuote].
Outputs: filename.itp. 
NOTE: It is your responsibility to write your own molecule name!\
\>", "CodeText",
 CellChangeTimes->{{3.885403668722089*^9, 
  3.885403718071143*^9}},ExpressionUUID->"c33f63ab-06f8-44b9-bc55-\
85bfab007abe"],

Cell[BoxData[
 RowBox[{
  RowBox[{"writeITPLines", "[", "fName_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"fOut", "=", 
      RowBox[{"OpenWrite", "[", 
       RowBox[{"fName", "<>", "\"\<.itp\>\""}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"WriteString", "[", 
      RowBox[{
      "fOut", ",", "\"\<[moleculetype]\\n\>\"", ",", 
       "\"\<moleculename    3\\n\>\""}], "]"}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "write", " ", "molecule", " ", "name", " ", "in", " ", "the", " ", 
       "generated", " ", "itp", " ", "file"}], "*)"}], "\[IndentingNewLine]", 
     
     RowBox[{"WriteString", "[", 
      RowBox[{"fOut", ",", "\"\<[ atoms ]\\n\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"WriteString", "[", 
        RowBox[{"fOut", ",", 
         RowBox[{"makeAtomLine", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
      "defAtm"}], ";", "\[IndentingNewLine]", 
     RowBox[{"WriteString", "[", 
      RowBox[{"fOut", ",", "\"\<[ constraints ]\\n\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"WriteString", "[", 
        RowBox[{"fOut", ",", 
         RowBox[{"makeConstraintLine", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
      "defCnstr"}], ";", "\[IndentingNewLine]", 
     RowBox[{"WriteString", "[", 
      RowBox[{"fOut", ",", "\"\<[ virtualsites3 ]\\n\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"WriteString", "[", 
        RowBox[{"fOut", ",", 
         RowBox[{"makeVsiteLine", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
      "defVS"}], " ", ";", "\[IndentingNewLine]", 
     RowBox[{"WriteString", "[", 
      RowBox[{"fOut", ",", "\"\<[ bonds ]\\n\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"WriteString", "[", 
        RowBox[{"fOut", ",", 
         RowBox[{"makeBondLine", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
      "defBond"}], ";", "\[IndentingNewLine]", 
     RowBox[{"WriteString", "[", 
      RowBox[{"fOut", ",", "\"\<[ angles ]\\n\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"WriteString", "[", 
        RowBox[{"fOut", ",", 
         RowBox[{"makeAngleLine", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
      "defAng"}], ";", "\[IndentingNewLine]", 
     RowBox[{"WriteString", "[", 
      RowBox[{"fOut", ",", "\"\<[ dihedrals ]\\n\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"WriteString", "[", 
        RowBox[{"fOut", ",", 
         RowBox[{"makeDihedralLine", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
      "defDih"}], ";", "\[IndentingNewLine]", 
     RowBox[{"WriteString", "[", 
      RowBox[{"fOut", ",", "\"\<[ exclusions ]\\n\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"WriteString", "[", 
        RowBox[{"fOut", ",", 
         RowBox[{"makePairLine", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
      "excl"}], ";", "\[IndentingNewLine]", 
     RowBox[{"WriteString", "[", 
      RowBox[{"fOut", ",", "\"\<[ pairs ]\\n\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"WriteString", "[", 
        RowBox[{"fOut", ",", 
         RowBox[{"makePairLine", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
      "pairs"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Close", "[", "fOut", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.884869436516692*^9, 3.884869442907875*^9}, {
  3.8848695465369062`*^9, 3.8848695980128183`*^9}, {3.884869668084141*^9, 
  3.884869718072956*^9}, {3.885402648273629*^9, 3.8854027033868723`*^9}, {
  3.885402774802472*^9, 3.885402777558363*^9}, {3.885402820862282*^9, 
  3.885402823133092*^9}, {3.8858975395038643`*^9, 3.885897555705229*^9}},
 CellLabel->
  "In[1215]:=",ExpressionUUID->"769ae444-ad78-4315-9993-83654d04a3ff"]
}, Closed]]
}, Open  ]],

