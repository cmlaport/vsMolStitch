   3.884689014868167*^9, 3.884689020014331*^9}, {3.88468914266575*^9, 
   3.884689176427279*^9}, {3.884689349777852*^9, 3.884689400008905*^9}, {
   3.884689435910708*^9, 3.884689446417395*^9}, {3.884689651023406*^9, 
   3.884689710467474*^9}, {3.8846897473919573`*^9, 3.8846898023559017`*^9}, {
   3.884689928942953*^9, 3.88468994881433*^9}, {3.884690022198429*^9, 
   3.884690037637772*^9}, {3.884690096492839*^9, 3.8846901482079144`*^9}, {
   3.884690188177842*^9, 3.8846903312999353`*^9}, {3.88469044483521*^9, 
