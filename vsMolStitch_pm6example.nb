   3.885385801157675*^9, 
   3.88538580306896*^9}},ExpressionUUID->"13a9d0c6-16f3-4666-b70f-\
85870188c9bc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"getitpInfo", "[", "monitp_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "itpres", ",", "aIdx", ",", "bIdx", ",", "cIdx", ",", "vIdx", ",", 
      "angIdx", ",", "dIdx", ",", "atm", ",", "cnstr", ",", "vs", ",", "bond",
       ",", "ang", ",", "dih"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"itpres", "=", 
      RowBox[{"DeleteCases", "[", 
       RowBox[{"monitp", ",", 
        RowBox[{"{", "}"}]}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{"delete", " ", "blank", " ", "lines"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"itpres", "=", 
      RowBox[{"Select", "[", 
       RowBox[{"itpres", ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "!=", "\"\<;\>\""}], ")"}], 
         "&"}]}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"delete", " ", "comment", " ", "lines"}], ",", " ", 
       RowBox[{
        RowBox[{"must", " ", "have", " ", "space", " ", "between"}], " ", ";",
         "  ", 
        RowBox[{"and", " ", "words"}]}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"aIdx", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"itpres", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<[\>\"", ",", "\"\<atoms\>\"", ",", "\"\<]\>\""}], 
          "}"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "getting", " ", "monomer", " ", "bonded", " ", "interaction", " ", 
       "line", " ", "positions"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"cIdx", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"itpres", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<[\>\"", ",", "\"\<constraints\>\"", ",", "\"\<]\>\""}],
           "}"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"vIdx", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"itpres", ",", 
         RowBox[{"{", 
          RowBox[{
          "\"\<[\>\"", ",", "\"\<virtualsites3\>\"", ",", "\"\<]\>\""}], 
          "}"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"bIdx", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"itpres", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<[\>\"", ",", "\"\<bonds\>\"", ",", "\"\<]\>\""}], 
          "}"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"angIdx", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"itpres", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<[\>\"", ",", "\"\<angles\>\"", ",", "\"\<]\>\""}], 
          "}"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"dIdx", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"itpres", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<[\>\"", ",", "\"\<dihedrals\>\"", ",", "\"\<]\>\""}], 
          "}"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"atm", "=", 
      RowBox[{"itpres", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"aIdx", "+", "1"}], ";;", 
         RowBox[{"cIdx", "-", "1"}]}], "]"}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "getting", " ", "monomer", " ", "bonded", " ", "interactions", " ", 
       "defintions"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"cnstr", "=", 
      RowBox[{"itpres", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"cIdx", "+", "1"}], ";;", 
         RowBox[{"vIdx", "-", "1"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"vs", "=", 
      RowBox[{"itpres", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"vIdx", "+", "1"}], ";;", 
         RowBox[{"bIdx", "-", "1"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"bond", " ", "=", " ", 
      RowBox[{"itpres", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"bIdx", "+", "1"}], ";;", 
         RowBox[{"angIdx", "-", "1"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"ang", " ", "=", "  ", 
      RowBox[{"itpres", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"angIdx", "+", "1"}], ";;", 
         RowBox[{"dIdx", "-", "1"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dih", " ", "=", " ", 
      RowBox[{"itpres", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"dIdx", "+", "1"}], ";;"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
      "atm", ",", "cnstr", ",", "vs", ",", "bond", ",", "ang", ",", "dih"}], 
      "}"}]}]}], "]"}]}]], "Input",
