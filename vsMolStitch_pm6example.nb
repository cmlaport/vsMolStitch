   3.884862408742854*^9}, {3.8848625514148693`*^9, 3.884862663285309*^9}, {
   3.884862723130389*^9, 3.884862736265156*^9}, {3.884862786187942*^9, 
   3.884862789695819*^9}, {3.884862824110463*^9, 3.884862826731556*^9}, {
   3.884863051889072*^9, 3.884863058703506*^9}, {3.884865534785429*^9, 
   3.88486555849953*^9}, 3.884866212871821*^9, {3.884866305145597*^9, 
   3.884866333450486*^9}, {3.884866428510064*^9, 3.884866428956229*^9}, {
   3.8848665343710327`*^9, 3.8848665616414623`*^9}, 3.884866630988205*^9, {
   3.884866705117729*^9, 3.8848667464466677`*^9}, {3.8848668257346687`*^9, 
   3.8848668903102217`*^9}, 3.884867045776389*^9, 3.8848671211625767`*^9, {
   3.8848816134579573`*^9, 3.884881623030015*^9}, {3.884882843015484*^9, 
   3.884882915407439*^9}, {3.884882985319386*^9, 3.8848829939443827`*^9}, {
   3.884883124251131*^9, 3.884883150046544*^9}, {3.885294037034481*^9, 
   3.885294040927237*^9}, {3.885398943677106*^9, 3.885399047551111*^9}, {
   3.885399089952577*^9, 3.885399189040264*^9}, {3.885399232030838*^9, 
   3.885399293915517*^9}, {3.885399333052024*^9, 3.885399340968548*^9}, {
   3.885399387583601*^9, 3.885399388435759*^9}, {3.885399445046187*^9, 
   3.885399448029594*^9}, {3.885399521031253*^9, 3.885399557300693*^9}, {
   3.885399631056183*^9, 3.885399675392075*^9}, {3.885399726849052*^9, 
   3.885399727120202*^9}, {3.885399815600679*^9, 3.885399822169323*^9}, {
   3.885400034707251*^9, 3.885400048192053*^9}, {3.885400135357267*^9, 
   3.8854001794585953`*^9}, {3.88540026888723*^9, 3.885400297405476*^9}, {
