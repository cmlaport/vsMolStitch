Cell["\<\
make(_)Line uses information compiled in the definitions for the constraints, \
virtual sites, bonds, angles, dihedrals, pairs and exclusions to format \
strings in a fixed column format for use in the itp file. This is not \
required but makes it easier to read .
NOTE: It is your responsibility to write your own molecule name!\
\>", "CodeText",
 CellChangeTimes->{{3.8848840756966267`*^9, 3.884884302491562*^9}, {
  3.884884440241612*^9, 3.884884519232443*^9}, {3.885403475893804*^9, 
  3.885403488594428*^9}},ExpressionUUID->"1f1b3f70-1254-4bb4-9cca-\
97817a89bf83"],

Cell[BoxData[
 RowBox[{
  RowBox[{"makeAtomLine", "[", 
   RowBox[{"{", 
    RowBox[{
    "aNum_", ",", "aType_", ",", "resNum_", ",", "resName_", ",", "aName_", 
     ",", "cgNum_", ",", "cg_", ",", "mass_"}], "}"}], "]"}], ":=", 
  RowBox[{"StringJoin", "[", 
   RowBox[{"ToString", "/@", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"iFormat", "[", 
       RowBox[{"aNum", ",", "5"}], "]"}], ",", 
      RowBox[{"aFormat", "[", 
       RowBox[{"aType", ",", "10"}], "]"}], ",", 
      RowBox[{"iFormat", "[", 
       RowBox[{"resNum", ",", "5"}], "]"}], ",", 
      RowBox[{"aFormat", "[", 
       RowBox[{"resName", ",", "5"}], "]"}], ",", 
      RowBox[{"aFormat", "[", 
       RowBox[{"aName", ",", "5"}], "]"}], ",", 
      RowBox[{"iFormat", "[", 
       RowBox[{"cgNum", ",", "5"}], "]"}], ",", 
      RowBox[{"fFormat", "[", 
       RowBox[{"cg", ",", "10", ",", "5"}], "]"}], ",", 
      RowBox[{"fFormat", "[", 
       RowBox[{"mass", ",", "10", ",", "5"}], "]"}], ",", "\"\<\\n\>\""}], 
     "}"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[1208]:=",ExpressionUUID->"42d49c7d-8915-4495-8043-b09ea0430f19"],

Cell[BoxData[
 RowBox[{
