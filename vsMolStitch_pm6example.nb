      RowBox[{"iFormat", "[", 
       RowBox[{"resNum", ",", "5"}], "]"}], ",", 
      RowBox[{"aFormat", "[", 
       RowBox[{"resName", ",", "5"}], "]"}], ",", 
      RowBox[{"aFormat", "[", 
       RowBox[{"aName", ",", "5"}], "]"}], ",", 
      RowBox[{"iFormat", "[", 
       RowBox[{"cgNum", ",", "5"}], "]"}], ",", 
      RowBox[{"fFormat", "[", 
       RowBox[{"cg", ",", "10", ",", "5"}], "]"}], ",", 
      RowBox[{"fFormat", "[", 
       RowBox[{"mass", ",", "10", ",", "5"}], "]"}], ",", "\"\<\\n\>\""}], 
     "}"}]}], "]"}]}]], "Input",
 CellLabel->
