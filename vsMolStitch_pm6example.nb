Cell["\<\
computeDummy calculates the coordinates of a dummy atom for a stiff-ring \
structured monomer.   Requires the coordinates of 3 atoms on the stiff ring. \
ra is the atom that the dummy site will connect to. b and c are the atoms \
that flank ra. Also requires a bond length (from QM calculations or \
experiment). Outputs a dummy atom coordinates.\
\>", "CodeText",
 CellChangeTimes->{{3.883747338358267*^9, 3.8837473431852207`*^9}, {
  3.883747398488818*^9, 3.8837474071539907`*^9}, {3.883747475708333*^9, 
  3.883747504249645*^9}, {3.8837475472496777`*^9, 3.8837475685709963`*^9}, {
  3.883747627286129*^9, 3.883747680744769*^9}, {3.883747727515717*^9, 
  3.883747900569194*^9}, {3.8853877058625393`*^9, 3.88538770734762*^9}, {
  3.8853938240076857`*^9, 3.88539382535233*^9}, {3.8853938586641903`*^9, 
  3.885394098773466*^9}, {3.885394137980633*^9, 3.88539413997386*^9}, {
  3.885394246419525*^9, 3.8853942472166967`*^9}, {3.8853943212890873`*^9, 
  3.885394436228877*^9}, {3.885394614070344*^9, 
  3.885394616611271*^9}},ExpressionUUID->"ebc9ad27-43bb-4a94-aef2-\
6bb56c56aeaa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"computeDummy", "[", 
   RowBox[{"ra_", ",", "rb_", ",", "rc_", ",", "lBond_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"v1", ",", "v2", ",", "v3", ",", "d"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"v1", "=", 
      RowBox[{"(", 
       RowBox[{"ra", "-", "rb"}], ")"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"v1", "=", 
      RowBox[{"v1", "/", 
       RowBox[{"Norm", "[", "v1", "]"}]}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "vector", " ", "calculated", " ", "from", " ", "atom", " ", 
        "position"}], ",", " ", 
       RowBox[{
       "normalized", " ", "as", " ", "a", " ", "unit", " ", "vector"}]}], 
      "*)"}], "\[IndentingNewLine]", 
     RowBox[{"v2", "=", 
      RowBox[{"(", 
       RowBox[{"ra", "-", "rc"}], ")"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"v2", "=", 
      RowBox[{"v2", "/", 
       RowBox[{"Norm", "[", "v2", "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"v3", "=", 
      RowBox[{"v1", "+", "v2"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "A", " ", "vector", " ", "is", " ", "calculated", " ", "by", " ", 
       "adding", " ", "two", " ", "vectors", " ", "stemming", " ", "from", 
       " ", "connecting", " ", "atom", " ", 
       RowBox[{"a", "."}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"v3", "=", 
      RowBox[{"v3", "/", 
       RowBox[{"Norm", "[", "v3", "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"v3", "=", 
      RowBox[{"v3", " ", "lBond"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "bond", " ", "length", " ", "l", " ", "gives", " ", "the", " ", 
       "vector", " ", "3", " ", "a", " ", "length"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"d", "=", 
      RowBox[{"v3", "+", "ra"}]}]}]}], "]"}], " "}]], "Input",
 CellChangeTimes->{
  3.883666479207198*^9, 3.883666512624226*^9, {3.883747878006428*^9, 
   3.883747880139327*^9}, {3.883754845320109*^9, 3.883754860578793*^9}, {
   3.8837609208186703`*^9, 3.883760958885168*^9}, {3.883760990626954*^9, 
   3.883761059343755*^9}, {3.883761277807197*^9, 3.883761309879732*^9}, 
   3.884276097849019*^9, 3.885387626349779*^9, {3.8853944179640636`*^9, 
   3.885394568104611*^9}, {3.887392707933381*^9, 3.887392710420089*^9}, {
   3.887392882241768*^9, 3.887392892793639*^9}, {3.887393221633155*^9, 
   3.88739323514263*^9}, {3.887393406392404*^9, 3.887393428532469*^9}, 
   3.888325401197775*^9, 3.888589605356015*^9},
 CellLabel->
