Cell["\<\
This section is useful for piecing together fused rings (addSpecial Bond) or \
adding monomers that are too stiff for proper dihedrals \
(addStiffpotential/addstiff monomer)\
\>", "Text",
 CellChangeTimes->{{3.933329530178668*^9, 3.933329633295418*^9}, {
  3.933329665679915*^9, 
  3.93332968695081*^9}},ExpressionUUID->"c45c1c63-71cd-4a13-a00e-\
1835101861fd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"addSpecialBond", "[", 
   RowBox[{"n1_", ",", 
    RowBox[{"{", 
     RowBox[{"a1_", ",", "b1_", ",", "c1_"}], "}"}], ",", "n2_", ",", 
    RowBox[{"{", 
     RowBox[{"a2_", ",", "b2_", ",", "c2_"}], "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "na1", ",", "nb1", ",", "nc1", ",", "na2", ",", "nb2", ",", "nc2"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"na1", ",", "nb1", ",", "nc1"}], "}"}], "=", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a1", ",", "b1", ",", "c1"}], "}"}], "+", 
       RowBox[{"offset", "[", 
        RowBox[{"[", "n1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"na2", ",", "nb2", ",", "nc2"}], "}"}], "=", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a2", ",", "b2", ",", "c2"}], "}"}], "+", 
       RowBox[{"offset", "[", 
        RowBox[{"[", "n2", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{
       RowBox[{"chemBonds", "[", 
        RowBox[{"[", "na1", "]"}], "]"}], ",", "na2"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{
       RowBox[{"chemBonds", "[", 
        RowBox[{"[", "na2", "]"}], "]"}], ",", "na1"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"defBond", ",", 
       RowBox[{"{", 
        RowBox[{"na2", ",", "na1", ",", "1"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"defAng", ",", 
       RowBox[{"{", 
        RowBox[{"na1", ",", "na2", ",", "nb2", ",", "1"}], "}"}]}], "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"defAng", ",", 
       RowBox[{"{", 
        RowBox[{"na2", ",", "na1", ",", "nb1", ",", "1"}], "}"}]}], "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"defDih", ",", 
       RowBox[{"{", 
        RowBox[{"nb1", ",", "na1", ",", "na2", ",", "nb2", ",", "2"}], 
        "}"}]}], "]"}], ";", " ", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"defDih", ",", 
       RowBox[{"{", 
        RowBox[{"na1", ",", "na2", ",", "nb2", ",", "nc2", ",", "2"}], 
        "}"}]}], "]"}], ";"}]}], "]"}], "  ", 
  RowBox[{"(*", 
   RowBox[{
   "changed", " ", "connections", " ", "to", " ", "match", " ", "potential", 
    " ", "definition"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.8883266283334427`*^9, 3.888326636331729*^9}, {
   3.888326670523019*^9, 3.888326673986417*^9}, 3.888326720988315*^9, {
   3.8883292121946163`*^9, 3.888329227741469*^9}, {3.888330575794404*^9, 
   3.888330579255924*^9}, {3.9844996491559877`*^9, 3.984499665123863*^9}, {
   3.984499702361793*^9, 3.98449970727488*^9}, {3.984500013871998*^9, 
   3.98450004801332*^9}},
 CellLabel->
  "In[760]:=",ExpressionUUID->"7b78d24d-12b6-4304-93f0-5994e5183a30"],

