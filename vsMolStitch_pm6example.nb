  3.885387614242712*^9}},ExpressionUUID->"cd472846-3154-4f32-8d6b-\
e13ac8f2f2c9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"computeDist", "[", 
   RowBox[{"monpdb_", ",", "a_", ",", "b_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"posns", ",", "aPos", ",", "bPos"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"posns", "=", 
      RowBox[{
       RowBox[{"getPDBInfo", "[", "monpdb", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"aPos", "=", 
      RowBox[{"posns", "[", 
       RowBox[{"[", "a", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"bPos", "=", 
      RowBox[{"posns", "[", 
       RowBox[{"[", "b", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Norm", "[", 
      RowBox[{"aPos", "-", "bPos"}], "]"}]}]}], "]"}]}]], "Input",
