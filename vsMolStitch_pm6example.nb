   3.885387690572439*^9}, 3.8853952709414787`*^9, {3.885395339767089*^9, 
   3.885395342455139*^9}},ExpressionUUID->"c97e4efb-57fa-462b-a269-\
3aeda49dedae"],

Cell[BoxData[
 RowBox[{
  RowBox[{"addFirstMonomer", "[", 
   RowBox[{"{", 
    RowBox[{"monpdb_", ",", "monitp_"}], "}"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "posns", ",", "anames", ",", "conects", ",", "resnames", ",", 
      "species"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "posns", ",", "anames", ",", "conects", ",", "resnames", ",", 
        "species"}], "}"}], "=", 
      RowBox[{"getPDBInfo", "[", "monpdb", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"saveAtomInfo", "[", 
      RowBox[{"posns", ",", "anames", ",", "resnames", ",", "species"}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "defAtm", ",", "defCnstr", ",", "defVS", ",", "defBond", ",", "defAng",
         " ", ",", "defDih"}], "}"}], "=", 
      RowBox[{"getitpInfo", "[", "monitp", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"chemBonds", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"chemBonds", ",", "conects"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"nMon", "=", "1"}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{"Update", " ", "the", " ", "residue", " ", "number"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"offset", ",", 
       RowBox[{"Length", "[", "defAtm", "]"}]}], "]"}], " ", 
     RowBox[{"(*", 
      RowBox[{"update", " ", "offset"}], "*)"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
