Cell["\<\
computeVSConstraint is an \[OpenCurlyDoubleQuote]on the fly\
\[CloseCurlyDoubleQuote] function. Calculates \[OpenCurlyQuote]weights\
\[CloseCurlyQuote] that dictate where a virtual atom is compared to 3 real \
atoms in planar, stiff rings. (Type 3 in gromacs manual, section 4.7) \
Requires a pdb table, the virtual site atom serial #, and the serial numbers \
of real atoms a, b and c in the monomer itp file.
Outputs a list of 2 weights of the virtual site relative to the 3 real atoms \
(called a and b in Agarwala et. al, 2022). This can be added to a monomer itp \
file.\
\>", "CodeText",
 CellChangeTimes->{{3.883236942493373*^9, 3.883236954830079*^9}, {
   3.8832371944851913`*^9, 3.883237373520089*^9}, {3.88323742019687*^9, 
   3.88323744911893*^9}, {3.883237819632213*^9, 3.883237823928692*^9}, {
   3.8837614747079277`*^9, 3.883761476465682*^9}, {3.883826663477518*^9, 
   3.883826709454707*^9}, {3.885394686499387*^9, 3.885394692282299*^9}, {
   3.8853947669829273`*^9, 3.885394797490038*^9}, {3.885394828429978*^9, 
   3.88539485433877*^9}, 3.885394886557736*^9, {3.885394949615439*^9, 
   3.885394990642047*^9}},ExpressionUUID->"900e67a2-1c25-47fa-a423-\
b30090bad263"],

Cell[BoxData[
 RowBox[{
  RowBox[{"computeVSConstraint", "[", 
   RowBox[{"monpdb_", ",", "vs_", ",", "a_", ",", "b_", ",", "c_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "ra", ",", "rb", ",", "rc", ",", "posns", ",", "v1", ",", "v2", ",", 
      "v3", ",", "d1", ",", "d2", ",", "d3", ",", "rvs", ",", "vvs"}], "}"}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"posns", "=", 
      RowBox[{
       RowBox[{"getPDBInfo", "[", "monpdb", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ra", ",", "rb", ",", "rc"}], "}"}], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"posns", "[", 
         RowBox[{"[", "a", "]"}], "]"}], ",", 
        RowBox[{"posns", "[", 
         RowBox[{"[", "b", "]"}], "]"}], ",", 
        RowBox[{"posns", "[", 
         RowBox[{"[", "c", "]"}], "]"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"v1", ",", "v2", ",", "v3"}], "}"}], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"rb", "-", "ra"}], ")"}], ",", 
        RowBox[{"(", 
         RowBox[{"rc", "-", "ra"}], ")"}], ",", 
        RowBox[{"Cross", "[", 
         RowBox[{"v1", ",", "v2"}], "]"}]}], "}"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "Make", " ", "a", " ", "coordinate", " ", "system", " ", "from", " ", 
       "real", " ", "sites"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"d1", ",", "d2", ",", "d3"}], "}"}], "=", 
      RowBox[{"Inverse", "[", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"v1", ",", "v2", ",", "v3"}], "}"}], "]"}], "]"}]}], ";", 
     " ", 
     RowBox[{"(*", 
      RowBox[{"make", " ", "dual", " ", "basis", " ", "set"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"rvs", "=", 
      RowBox[{"posns", "[", 
       RowBox[{"[", "vs", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"vvs", "=", 
      RowBox[{"rvs", "-", "ra"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"d1", ".", "vvs"}], ",", 
       RowBox[{"d2", ".", "vvs"}]}], "}"}]}]}], " ", 
   RowBox[{"(*", 
    RowBox[{
    "project", " ", "the", " ", "vsite", " ", "vector", " ", "onto", " ", 
     "dual", " ", "basis", " ", "set"}], "*)"}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.88262610011872*^9, 3.8826261269819593`*^9}, {
   3.882626166301353*^9, 3.882626201672216*^9}, 3.882626237021121*^9, {
