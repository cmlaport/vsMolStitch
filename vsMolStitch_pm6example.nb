Cell["\<\
genPairnExcl uses the conects list to find bonds, angles and proper \
dihedrals. From this info global lists of pairs and exclusions are generated. \
This gets added to the final itp file.
Required inputs: chemBonds or compiled list of conects from each residue.
Outputs: pairs and excl(usions)\
\>", "CodeText",
 CellChangeTimes->{
  3.884173280727702*^9, {3.8842763271285686`*^9, 3.884276630021316*^9}, {
   3.884276662295823*^9, 3.884276787058848*^9}, {3.884883031736521*^9, 
   3.8848831184525146`*^9}, {3.8848831538523273`*^9, 3.884883154101466*^9}, {
   3.884883186243011*^9, 
   3.8848833862899427`*^9}},ExpressionUUID->"d2b28854-8b71-4010-8f35-\
a4783a0f21c9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"genPairnExcl", "[", "conects_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"b", ",", "a", ",", "d", ",", "pb", ",", "pa", ",", "pd"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"b", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"conects", "[", 
               RowBox[{"[", 
                RowBox[{"s", ",", "1"}], "]"}], "]"}], ",", "#"}], "}"}], 
            "&"}], "/@", 
           RowBox[{"conects", "[", 
            RowBox[{"[", 
             RowBox[{"s", ",", 
              RowBox[{"2", ";;"}]}], "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"s", ",", "1", ",", 
            RowBox[{"Length", "[", "conects", "]"}]}], "}"}]}], "]"}], ",", 
        "1"}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{"list", " ", "of", " ", "bonds", " ", 
       RowBox[{"{", 
        RowBox[{"ai", ",", "aj"}], "}"}], " ", "generated", " ", "from", " ", 
       "conects", " ", "list"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"a", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"b", "[", 
               RowBox[{"[", 
                RowBox[{"s", ",", "1"}], "]"}], "]"}], ",", 
              RowBox[{"b", "[", 
               RowBox[{"[", 
                RowBox[{"s", ",", "2"}], "]"}], "]"}], ",", "#"}], " ", "}"}],
             "&"}], "/@", 
           RowBox[{"Complement", "[", 
            RowBox[{
             RowBox[{"conects", "[", 
              RowBox[{"[", 
               RowBox[{"b", "[", 
                RowBox[{"[", 
                 RowBox[{"s", ",", "2"}], "]"}], "]"}], "]"}], "]"}], ",", 
             RowBox[{"b", "[", 
              RowBox[{"[", "s", "]"}], "]"}]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"s", ",", "1", ",", 
            RowBox[{"Length", "[", "b", "]"}]}], "}"}]}], "]"}], ",", "1"}], 
       "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{"list", " ", "of", " ", "angles", " ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"ai", ",", "aj", ",", "ak"}], "}"}], ".", " ", "Get"}], " ", 
       "ai", " ", "and", " ", "aj", " ", "from", " ", "bonds", " ", 
       RowBox[{"list", ".", " ", "Complement"}], " ", "finds", " ", "atom", 
       " ", "number", " ", 
       RowBox[{"(", "ak", ")"}], " ", "connected", " ", "to", " ", "aj", " ", 
       "that", " ", 
       RowBox[{"aren", "'"}], "t", " ", "ai", " ", "or", " ", 
       RowBox[{"aj", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"d", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"a", "[", 
               RowBox[{"[", 
                RowBox[{"s", ",", "1"}], "]"}], "]"}], ",", 
              RowBox[{"a", "[", 
               RowBox[{"[", 
                RowBox[{"s", ",", "2"}], "]"}], "]"}], ",", 
              RowBox[{"a", "[", 
               RowBox[{"[", 
                RowBox[{"s", ",", "3"}], "]"}], "]"}], ",", "#"}], " ", "}"}],
             "&"}], "/@", 
           RowBox[{"Complement", "[", 
            RowBox[{
             RowBox[{"conects", "[", 
              RowBox[{"[", 
               RowBox[{"a", "[", 
                RowBox[{"[", 
                 RowBox[{"s", ",", "3"}], "]"}], "]"}], "]"}], "]"}], ",", 
             RowBox[{"a", "[", 
              RowBox[{"[", "s", "]"}], "]"}]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"s", ",", "1", ",", 
            RowBox[{"Length", "[", "a", "]"}]}], "}"}]}], "]"}], ",", "1"}], 
       "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"list", " ", "of", " ", "dihedrals", " ", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"ai", ",", "aj", ",", "ak", ",", "al"}], "}"}], ".", " ", 
         "Get"}], " ", "ai"}], ",", " ", 
       RowBox[{"aj", " ", "and", " ", "ak", " ", "from", " ", "angles", " ", 
        RowBox[{"list", ".", " ", "Complement"}], " ", "finds", " ", 
        "numbers", " ", "connected", " ", "to", " ", "ak", " ", "that", " ", 
        RowBox[{"aren", "'"}], "t", " ", "ai"}], ",", 
       RowBox[{"aj", " ", "or", " ", "ak"}]}], "*)"}], "\[IndentingNewLine]", 
     
     RowBox[{"pb", "=", 
      RowBox[{"Sort", "/@", "b"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"pa", "=", 
      RowBox[{"Sort", "/@", 
       RowBox[{"(", 
        RowBox[{"a", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", "3"}], "}"}]}], "]"}], "]"}], ")"}]}]}], ";", 
     " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "exclusions", " ", "associated", " ", "by", " ", "an", " ", "angle"}], 
       ",", " ", 
       RowBox[{
       "sorted", " ", "by", " ", "the", " ", "lowest", " ", "atom", " ", 
        "number"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"pd", "=", 
      RowBox[{"Sort", "/@", 
       RowBox[{"(", 
        RowBox[{"d", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", "4"}], "}"}]}], "]"}], "]"}], ")"}]}]}], ";", 
     " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "exclusions", " ", "associated", " ", "by", " ", "a", " ", 
        "dihedral"}], ",", " ", 
       RowBox[{
       "sorted", " ", "by", " ", "the", " ", "lowest", " ", "atom", " ", 
        "number"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"excl", "=", 
      RowBox[{"Sort", "[", 
       RowBox[{"DeleteDuplicates", "[", 
        RowBox[{"Join", "[", 
         RowBox[{"pb", ",", "pa", ",", "pd"}], "]"}], "]"}], "]"}]}], ";", 
     " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
        RowBox[{"exclusions", ".", " ", "join"}], " ", "all", " ", "lists"}], 
       ",", " ", 
       RowBox[{"remove", " ", 
        RowBox[{"duplicates", ".", " ", "Sorted"}]}]}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"pairs", "=", 
      RowBox[{"Complement", "[", 
       RowBox[{"pd", ",", "pb", ",", "pa"}], "]"}]}], ";"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"pairs", ".", " ", "1"}], "-", 
    RowBox[{
    "4", " ", "bonded", " ", "interactions", " ", "that", " ", "are", " ", 
     "neither", " ", "a", " ", "bond", " ", "or", " ", "an", " ", "angle"}]}],
    "*)"}]}]], "Input",
 CellChangeTimes->{{3.884819765316268*^9, 3.884819939602363*^9}, {
   3.884820024326934*^9, 3.884820055367478*^9}, {3.884820120831828*^9, 
   3.884820128798361*^9}, {3.884854821581534*^9, 3.8848548519671907`*^9}, {
   3.88485502378935*^9, 3.8848551251242857`*^9}, {3.884859248479567*^9, 
