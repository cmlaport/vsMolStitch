Cell["\<\
addToPotential uses the connecting atom and specified flanking atoms from two \
ring structures to add 1 bond,2 angles,2 impropers,1 dihedral,1 chemBond to \
global lists of interactions,for monomer n1 bonded at a1,b1,c1 to monomer n2 \
bonded at a2,b2,c2. This can be used as a standalone function to add a \
special bond or within addNextMonomer to update the potentials list for the \
building polymer.
IMPORTANT! THE ANGLE AND DIHEDRAL POTENTIALS ARE DETERMINED BY WHAT YOU CALL \
B AND C.  Choose these to match your calculated potential.
Inputs:residue # of monomer 1, {the serial numbers of atoms from the monomer \
input file: connecting atom a1 and flanking atoms b1 and c1.}
residue # of monomer 2, {the serial numbers of atoms from the monomer input \
file: the connecting atom a2 and flanking atoms b2 and c2.}\
\>", "CodeText",
 CellChangeTimes->{
  3.884173280727702*^9, {3.8842763271285686`*^9, 3.884276630021316*^9}, {
   3.884276662295823*^9, 3.884276787058848*^9}, {3.885398340232926*^9, 
   3.8853983405018167`*^9}, {3.885398378863377*^9, 
   3.885398442270809*^9}},ExpressionUUID->"d53aecda-82a7-4107-b3fd-\
108ecb60d18e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"addToPotential", "[", 
   RowBox[{"n1_", ",", 
    RowBox[{"{", 
     RowBox[{"a1_", ",", "b1_", ",", "c1_"}], "}"}], ",", "n2_", ",", 
    RowBox[{"{", 
     RowBox[{"a2_", ",", "b2_", ",", "c2_"}], "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "na1", ",", "nb1", ",", "nc1", ",", "na2", ",", "nb2", ",", "nc2"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"na1", ",", "nb1", ",", "nc1"}], "}"}], "=", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a1", ",", "b1", ",", "c1"}], "}"}], "+", 
       RowBox[{"offset", "[", 
        RowBox[{"[", "n1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"na2", ",", "nb2", ",", "nc2"}], "}"}], "=", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a2", ",", "b2", ",", "c2"}], "}"}], "+", 
       RowBox[{"offset", "[", 
        RowBox[{"[", "n2", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{
       RowBox[{"chemBonds", "[", 
        RowBox[{"[", "na1", "]"}], "]"}], ",", "na2"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{
       RowBox[{"chemBonds", "[", 
        RowBox[{"[", "na2", "]"}], "]"}], ",", "na1"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"defBond", ",", 
       RowBox[{"{", 
        RowBox[{"na2", ",", "na1", ",", "1"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"defAng", ",", 
       RowBox[{"{", 
        RowBox[{"na1", ",", "na2", ",", "nb2", ",", "1"}], "}"}]}], "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"defAng", ",", 
       RowBox[{"{", 
        RowBox[{"na2", ",", "na1", ",", "nb1", ",", "1"}], "}"}]}], "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"defDih", ",", 
       RowBox[{"{", 
        RowBox[{"na1", ",", "na2", ",", "nc2", ",", "nb2", ",", "2"}], 
        "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"defDih", ",", 
       RowBox[{"{", 
        RowBox[{"na2", ",", "na1", ",", "nc1", ",", "nb1", ",", "2"}], 
        "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"defDih", ",", 
       RowBox[{"{", 
        RowBox[{"nb2", ",", "na2", ",", "na1", ",", "nb1", ",", "3"}], 
        "}"}]}], "]"}], ";"}]}], "]"}]}]], "Input",
