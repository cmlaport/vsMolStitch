Cell["\<\
getitpInfo requires an itp file that has been imported as a table from the \
input file section. 
The itp file must have the following sections: [atoms], [constraints], \
[virtualsites3], [bonds], [angles], [dihedrals]. In that order. 
The function parses the itp file to extract information from each section. \
Returns a list of lists of the following:
getitpInfo[[1]] monomer atom definitions
getitpInfo[[2]] monomer constraint definitions
getitpInfo[[3]] monomer virtual site definitions
getitpInfo[[4]] monomer bond definitions
getitpInfo[[5]] monomer angles definitions
getitpInfo[[6]] monomer dihedral definitions\
\>", "CodeText",
 CellChangeTimes->{{3.88323009380107*^9, 3.883230099818365*^9}, {
   3.883230143885825*^9, 3.883230401748928*^9}, {3.8832319649731817`*^9, 
   3.883232032414851*^9}, 3.883232953061839*^9, {3.883235844199977*^9, 
   3.883235857530685*^9}, {3.883235906872696*^9, 3.883235960894466*^9}, {
   3.883236044705669*^9, 3.883236159824305*^9}, {3.883747202610264*^9, 
   3.8837472041532383`*^9}, {3.8853855920504923`*^9, 3.885385599567299*^9}, {
   3.885385801157675*^9, 
   3.88538580306896*^9}},ExpressionUUID->"13a9d0c6-16f3-4666-b70f-\
85870188c9bc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"getitpInfo", "[", "monitp_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "itpres", ",", "aIdx", ",", "bIdx", ",", "cIdx", ",", "vIdx", ",", 
      "angIdx", ",", "dIdx", ",", "atm", ",", "cnstr", ",", "vs", ",", "bond",
       ",", "ang", ",", "dih"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"itpres", "=", 
      RowBox[{"DeleteCases", "[", 
       RowBox[{"monitp", ",", 
        RowBox[{"{", "}"}]}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{"delete", " ", "blank", " ", "lines"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"itpres", "=", 
      RowBox[{"Select", "[", 
       RowBox[{"itpres", ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "!=", "\"\<;\>\""}], ")"}], 
         "&"}]}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"delete", " ", "comment", " ", "lines"}], ",", " ", 
       RowBox[{
        RowBox[{"must", " ", "have", " ", "space", " ", "between"}], " ", ";",
         "  ", 
        RowBox[{"and", " ", "words"}]}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"aIdx", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"itpres", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<[\>\"", ",", "\"\<atoms\>\"", ",", "\"\<]\>\""}], 
          "}"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "getting", " ", "monomer", " ", "bonded", " ", "interaction", " ", 
       "line", " ", "positions"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"cIdx", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"itpres", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<[\>\"", ",", "\"\<constraints\>\"", ",", "\"\<]\>\""}],
           "}"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"vIdx", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"itpres", ",", 
         RowBox[{"{", 
          RowBox[{
          "\"\<[\>\"", ",", "\"\<virtualsites3\>\"", ",", "\"\<]\>\""}], 
          "}"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"bIdx", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"itpres", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<[\>\"", ",", "\"\<bonds\>\"", ",", "\"\<]\>\""}], 
          "}"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"angIdx", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"itpres", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<[\>\"", ",", "\"\<angles\>\"", ",", "\"\<]\>\""}], 
          "}"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"dIdx", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"itpres", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<[\>\"", ",", "\"\<dihedrals\>\"", ",", "\"\<]\>\""}], 
          "}"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"atm", "=", 
      RowBox[{"itpres", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"aIdx", "+", "1"}], ";;", 
         RowBox[{"cIdx", "-", "1"}]}], "]"}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "getting", " ", "monomer", " ", "bonded", " ", "interactions", " ", 
       "defintions"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"cnstr", "=", 
      RowBox[{"itpres", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"cIdx", "+", "1"}], ";;", 
         RowBox[{"vIdx", "-", "1"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"vs", "=", 
      RowBox[{"itpres", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"vIdx", "+", "1"}], ";;", 
         RowBox[{"bIdx", "-", "1"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"bond", " ", "=", " ", 
      RowBox[{"itpres", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"bIdx", "+", "1"}], ";;", 
         RowBox[{"angIdx", "-", "1"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"ang", " ", "=", "  ", 
      RowBox[{"itpres", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"angIdx", "+", "1"}], ";;", 
         RowBox[{"dIdx", "-", "1"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dih", " ", "=", " ", 
      RowBox[{"itpres", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"dIdx", "+", "1"}], ";;"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
      "atm", ",", "cnstr", ",", "vs", ",", "bond", ",", "ang", ",", "dih"}], 
      "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.882957855260532*^9, 3.882957924359424*^9}, {
