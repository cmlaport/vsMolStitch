Cell["\<\
Getting a, b, c order correct for adding monomers can be confusing, \
visualizing the structure with colored spheres according to the elements\
\>", "Text",
 CellChangeTimes->{{3.9844795251553793`*^9, 
  3.984479533284369*^9}},ExpressionUUID->"345621f5-72c2-4c99-8356-\
21875f157294"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"colornames", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"elements", "/.", 
         RowBox[{"\"\<Cl\>\"", "->", "Green"}]}], "/.", 
        RowBox[{"\"\<C\>\"", "->", "Gray"}]}], "/.", 
       RowBox[{"\"\<S\>\"", "->", "Yellow"}]}], "/.", 
      RowBox[{"\"\<N\>\"", "->", "Blue"}]}], "/.", 
     RowBox[{"\"\<F\>\"", "->", "Cyan"}]}], "/.", 
    RowBox[{"\"\<O\>\"", "->", "Red"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Graphics3D", "[", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Hue", "[", 
       RowBox[{"colornames", "[", 
        RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
      RowBox[{"Sphere", "[", 
       RowBox[{
        RowBox[{"atomXYZ", "[", 
         RowBox[{"[", "i", "]"}], "]"}], ",", "0.09"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "1", ",", 
      RowBox[{"Length", "[", "atomXYZ", "]"}]}], "}"}]}], "]"}], 
  "]"}]}], "Input",
