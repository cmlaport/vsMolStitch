Cell[BoxData[
 RowBox[{
  RowBox[{"addNextMonomerH", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"newpdb_", ",", "newitp_"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"an_", ",", "bn_", ",", "cn_"}], "}"}], ",", "Ores_", ",", 
    RowBox[{"{", 
     RowBox[{"ao_", ",", "bo_", ",", "co_"}], "}"}], ",", "lBond_", ",", 
    RowBox[{"phi_", ":", "180.0"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "posns", ",", "anames", ",", "conects", ",", "resnames", ",", "species", 
      ",", "movedMon"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "posns", ",", "anames", ",", "conects", ",", "resnames", ",", 
        "species"}], "}"}], "=", 
      RowBox[{"getPDBInfo", "[", "newpdb", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"movedMon", "=", 
      RowBox[{"moveMonomer", "[", 
       RowBox[{
       "posns", ",", "Ores", ",", "an", ",", "bn", ",", "cn", ",", "ao", ",", 
        "bo", ",", "co", ",", "lBond", ",", "phi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"saveAtomInfo", "[", 
      RowBox[{"movedMon", ",", "anames", ",", "resnames", ",", "species"}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"chemBonds", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"chemBonds", ",", 
        RowBox[{"conects", "+", 
         RowBox[{"offset", "[", 
          RowBox[{"[", 
           RowBox[{"-", "1"}], "]"}], "]"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"saveITPInfo", "[", "newitp", "]"}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"nMon", "=", 
      RowBox[{"nMon", "+", "1"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"offset", ",", 
       RowBox[{
        RowBox[{"offset", "[", 
         RowBox[{"[", 
          RowBox[{"-", "1"}], "]"}], "]"}], "+", 
        RowBox[{"Length", "[", "anames", "]"}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"addToPotentialH", "[", 
      RowBox[{"nMon", ",", 
       RowBox[{"{", 
        RowBox[{"an", ",", "bn", ",", "cn"}], "}"}], ",", "Ores", ",", 
       RowBox[{"{", 
