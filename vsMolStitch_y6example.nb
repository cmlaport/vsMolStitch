Cell[BoxData[
 RowBox[{
  RowBox[{"addStiffMon", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"newpdb_", ",", "newitp_"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"an_", ",", "bn_", ",", "cn_"}], "}"}], ",", "Ores_", ",", 
    RowBox[{"{", 
     RowBox[{"ao_", ",", "bo_", ",", "co_"}], "}"}], ",", "lBond_", ",", 
    "phi_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "posns", ",", "anames", ",", "conects", ",", "resnames", ",", "species", 
      ",", "movedMon"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "posns", ",", "anames", ",", "conects", ",", "resnames", ",", 
        "species"}], "}"}], "=", 
      RowBox[{"getPDBInfo", "[", "newpdb", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"movedMon", "=", 
      RowBox[{"moveMonomer", "[", 
       RowBox[{
       "posns", ",", "Ores", ",", "an", ",", "bn", ",", "cn", ",", "ao", ",", 
        "bo", ",", "co", ",", "lBond", ",", "phi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"chemBonds", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"chemBonds", ",", 
        RowBox[{"conects", "+", 
         RowBox[{"offset", "[", 
          RowBox[{"[", 
           RowBox[{"-", "1"}], "]"}], "]"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"saveAtomInfo", "[", 
      RowBox[{"movedMon", ",", "anames", ",", "resnames", ",", "species"}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"saveITPInfo", "[", "newitp", "]"}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"nMon", "=", 
      RowBox[{"nMon", "+", "1"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"offset", ",", 
       RowBox[{
        RowBox[{"offset", "[", 
         RowBox[{"[", 
          RowBox[{"-", "1"}], "]"}], "]"}], "+", 
        RowBox[{"Length", "[", "anames", "]"}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
