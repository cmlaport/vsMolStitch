Cell[CellGroupData[{

Cell["Grofile and itp formatting", "Subsection",
 CellChangeTimes->{{3.884868592376005*^9, 
  3.88486859726982*^9}},ExpressionUUID->"6ecb9a7d-bb45-47cd-94b0-\
f49d60807923"],

Cell["\<\
makeGroLine formats a single line of string in fixed column format according \
to Gromacs specifications.
Required input: residue number list, residue names list, atom names list, \
x,y,z coordinates. Outputs string.\
\>", "CodeText",
 CellChangeTimes->{{3.884883505013112*^9, 3.8848835913651114`*^9}, {
  3.88488373288678*^9, 
  3.884883897126429*^9}},ExpressionUUID->"202f61cf-b227-4eeb-960c-\
8df05da55371"],

Cell[BoxData[
 RowBox[{
  RowBox[{"makeGroLine", "[", 
   RowBox[{"{", 
    RowBox[{
    "nRes_", ",", "resName_", ",", "atName_", ",", "atNum_", ",", "x_", ",", 
     "y_", ",", "z_"}], "}"}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"StringJoin", "[", 
   RowBox[{"ToString", "/@", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"iFormat", "[", 
       RowBox[{"nRes", ",", "5"}], "]"}], ",", 
      RowBox[{"aFormat", "[", 
       RowBox[{"resName", ",", "5"}], "]"}], ",", 
      RowBox[{"aFormat", "[", 
       RowBox[{"atName", ",", "5"}], "]"}], ",", 
      RowBox[{"iFormat", "[", 
       RowBox[{"atNum", ",", "5"}], "]"}], ",", 
      RowBox[{"fFormat", "[", 
       RowBox[{"x", ",", "8", ",", "3"}], "]"}], ",", 
      RowBox[{"fFormat", "[", 
       RowBox[{"y", ",", "8", ",", "3"}], "]"}], ",", 
      RowBox[{"fFormat", "[", 
       RowBox[{"z", ",", "8", ",", "3"}], "]"}], ",", "\"\<\\n\>\""}], 
     "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.884855044091514*^9, 3.8848550464497643`*^9}, 
   3.88485511961795*^9, 3.884868357630019*^9, {3.884868622831044*^9, 
   3.884868625511035*^9}, {3.8848699378086653`*^9, 3.884869939907971*^9}, {
   3.884883396068239*^9, 3.884883399454908*^9}},
 CellLabel->
  "In[323]:=",ExpressionUUID->"656f1842-4138-44fc-babe-8b603242b07e"],

Cell["\<\
writeGroLines formats the entire gro file . 
Required inputs : \"filename\".
Outputs: filename.gro. 
NOTE: It is your responsibility to write your own molecule name and overwrite \
box dimensions which are set to 1.0 1.0 1.0!\
\>", "CodeText",
 CellChangeTimes->{{3.884883909122754*^9, 3.884884035131303*^9}, {
  3.88540337486518*^9, 3.8854034585218487`*^9}, {3.885403491700273*^9, 
  3.885403518674972*^9}, {3.8854036944251537`*^9, 
  3.8854036957953053`*^9}},ExpressionUUID->"c31801b9-e4a9-4584-b938-\
4d7ada6b6432"],

Cell[BoxData[
 RowBox[{
  RowBox[{"writeGroLines", "[", "fName_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"nAtoms", "=", 
      RowBox[{
       RowBox[{"offset", "[", 
        RowBox[{"[", 
         RowBox[{"2", ";;", 
          RowBox[{"-", "1"}]}], "]"}], "]"}], "-", 
       RowBox[{"offset", "[", 
        RowBox[{"[", 
         RowBox[{"1", ";;", 
          RowBox[{"-", "2"}]}], "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"rNums", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{"i", ",", 
           RowBox[{"nAtoms", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"Length", "[", "resName", "]"}]}], "}"}]}], "]"}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"rNames", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"resName", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", 
           RowBox[{"nAtoms", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", 
           RowBox[{"Length", "[", "resName", "]"}]}], "}"}]}], "]"}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"atNums", "=", 
      RowBox[{"Range", "[", 
       RowBox[{"Length", "[", "atomName", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"outData", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"rNums", ",", "rNames", ",", "atomName", ",", "atNums"}], 
          "}"}], ",", 
         RowBox[{"Transpose", "[", "atomXYZ", "]"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"fOut", "=", 
      RowBox[{"OpenWrite", "[", 
       RowBox[{"fName", "<>", "\"\<.gro\>\""}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"outStrings", "=", 
      RowBox[{"makeGroLine", "/@", "outData"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"WriteString", "[", 
      RowBox[{"fOut", ",", "\"\<molecule\\n\>\""}], "]"}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "write", " ", "molecule", " ", "name", " ", "in", " ", "the", " ", 
       "generated", " ", "itp", " ", "file"}], "*)"}], "\[IndentingNewLine]", 
     
     RowBox[{"WriteString", "[", 
      RowBox[{"fOut", ",", 
       RowBox[{"Length", "[", "atomName", "]"}], ",", "\"\<\\n\>\""}], "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"WriteString", "[", 
        RowBox[{"fOut", ",", "#"}], "]"}], "&"}], "/@", "outStrings"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"WriteString", "[", 
      RowBox[{"fOut", ",", "\"\<1.0 1.0 1.0\\n\>\""}], "]"}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "overwrite", " ", "box", " ", "size", " ", "in", " ", "the", " ", 
       "generated", " ", "itp", " ", "file"}], "*)"}], "\[IndentingNewLine]", 
     
     RowBox[{"Close", "[", "fOut", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.8848691331472483`*^9, 3.884869134560902*^9}, 
   3.884869167742009*^9, {3.884869306902204*^9, 3.884869318480843*^9}, {
   3.8848726862026978`*^9, 3.884872688067087*^9}, {3.885402440889327*^9, 
   3.885402542936561*^9}, {3.885402594699504*^9, 3.885402641612783*^9}, {
   3.88540290834153*^9, 3.885402918944243*^9}, {3.8854029860035887`*^9, 
   3.885403032170986*^9}, {3.885403062740172*^9, 3.885403097702454*^9}, {
   3.885403153491529*^9, 3.885403166137199*^9}, {3.885403310284738*^9, 
   3.88540332976935*^9}, {3.885897584458946*^9, 3.8858976029641*^9}, {
   3.888331124657867*^9, 3.8883311252887573`*^9}},
 CellLabel->
  "In[324]:=",ExpressionUUID->"df0aebcc-5928-45ae-a5bd-da91f716b6b5"],

Cell["\<\
make(_)Line uses information compiled in the definitions for the constraints, \
virtual sites, bonds, angles, dihedrals, pairs and exclusions to format \
strings in a fixed column format for use in the itp file. This is not \
required but makes it easier to read .
NOTE: It is your responsibility to write your own molecule name!\
\>", "CodeText",
 CellChangeTimes->{{3.8848840756966267`*^9, 3.884884302491562*^9}, {
  3.884884440241612*^9, 3.884884519232443*^9}, {3.885403475893804*^9, 
  3.885403488594428*^9}},ExpressionUUID->"1f1b3f70-1254-4bb4-9cca-\
97817a89bf83"],

Cell[BoxData[
 RowBox[{
  RowBox[{"makeAtomLine", "[", 
   RowBox[{"{", 
    RowBox[{
