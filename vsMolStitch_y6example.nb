Cell["\<\
addFirstMonomer initializes the global lists by specifying a first monomer. \
Adds the coordinates, chem bonds and itp information to global lists.
Requires a pdb and itp file imported as a table.\
\>", "CodeText",
 CellChangeTimes->{{3.883237747079797*^9, 3.883237792540896*^9}, {
   3.883747239793157*^9, 3.883747303622965*^9}, {3.883747353571352*^9, 
   3.88374735917124*^9}, {3.884275994517433*^9, 3.884276034869904*^9}, {
   3.885387582371677*^9, 3.885387592530032*^9}, {3.885387689898888*^9, 
   3.885387690572439*^9}, 3.8853952709414787`*^9, {3.885395339767089*^9, 
   3.885395342455139*^9}},ExpressionUUID->"c97e4efb-57fa-462b-a269-\
3aeda49dedae"],

Cell[BoxData[
 RowBox[{
  RowBox[{"addFirstMonomer", "[", 
   RowBox[{"{", 
    RowBox[{"monpdb_", ",", "monitp_"}], "}"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "posns", ",", "anames", ",", "conects", ",", "resnames", ",", 
      "species"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "posns", ",", "anames", ",", "conects", ",", "resnames", ",", 
        "species"}], "}"}], "=", 
      RowBox[{"getPDBInfo", "[", "monpdb", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"saveAtomInfo", "[", 
      RowBox[{"posns", ",", "anames", ",", "resnames", ",", "species"}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "defAtm", ",", "defCnstr", ",", "defVS", ",", "defBond", ",", "defAng",
         " ", ",", "defDih"}], "}"}], "=", 
      RowBox[{"getitpInfo", "[", "monitp", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"chemBonds", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"chemBonds", ",", "conects"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"nMon", "=", "1"}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{"Update", " ", "the", " ", "residue", " ", "number"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"offset", ",", 
       RowBox[{"Length", "[", "defAtm", "]"}]}], "]"}], " ", 
     RowBox[{"(*", 
      RowBox[{"update", " ", "offset"}], "*)"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
