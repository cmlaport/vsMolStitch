Cell["\<\
moveMonomer calculates the coordinates of a monomer that is moved into place \
next to an existing polymer residue. Outputs coordinates of the new monomer. 
NOTE: an,bn,cn refer to the NEW MONOMER, ao,bo,co refer to an OLD residue, \
previously added.
a(line# for connecting atom), b (line# flanking atom used in dihedral angle), \
c (other flanking atom). lbond is the bond length between the two connecting \
atoms an and ao. theta is the dihedral angle for bn-an-ao-bo. \
\>", "CodeText",
 CellChangeTimes->{{3.8837479335624847`*^9, 3.883747941431404*^9}, {
   3.8837480725967903`*^9, 3.883748728777832*^9}, {3.884277145784965*^9, 
   3.8842771790638647`*^9}, 3.885395578731818*^9, {3.885395646524279*^9, 
   3.885395692757277*^9}, {3.8853974479688673`*^9, 3.885397549893476*^9}, {
   3.885397593803583*^9, 3.8853977124386044`*^9}, {3.8853983116240263`*^9, 
   3.8853983198583183`*^9}},ExpressionUUID->"3a801c16-7c7a-4b86-9792-\
f8d320912d13"],

Cell[BoxData[
 RowBox[{
  RowBox[{"moveMonomer", "[", 
   RowBox[{
   "newPos_", ",", "Ores_", ",", "an_", ",", "bn_", ",", "cn_", ",", "ao_", 
    ",", "bo_", ",", "co_", ",", "lBond_", ",", "phi_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "oA", ",", "rdo", ",", "rdn", ",", "ran", ",", "rbn", ",", "rcn", ",", 
      "rao", ",", "rbo", ",", "rco", ",", "Matr", ",", "movedMon", ",", "dih",
       ",", "Matr2"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ran", ",", "rbn", ",", "rcn"}], "}"}], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"newPos", "[", 
         RowBox[{"[", "an", "]"}], "]"}], ",", 
        RowBox[{"newPos", "[", 
         RowBox[{"[", "bn", "]"}], "]"}], ",", 
        RowBox[{"newPos", "[", 
         RowBox[{"[", "cn", "]"}], "]"}]}], "}"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "new", " ", "residue", " ", "connecting", " ", "atom", " ", 
       "coordinates"}], "*)"}], " ", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"rao", ",", "rbo", ",", "rco"}], "}"}], "=", 
      RowBox[{"atomXYZ", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"ao", ",", "bo", ",", "co"}], "}"}], "+", 
         RowBox[{"offset", "[", 
          RowBox[{"[", "Ores", "]"}], "]"}]}], "]"}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "old", " ", "residue", " ", "connecting", " ", "atom", " ", 
        "coordinates"}], ",", " ", 
       RowBox[{"use", " ", "residue", " ", "number", " ", "offset"}]}], 
      "*)"}], " ", "\[IndentingNewLine]", 
     RowBox[{"rdo", "=", 
      RowBox[{"computeDummy", "[", 
       RowBox[{"rao", ",", "rbo", ",", "rco", ",", "lBond"}], "]"}]}], ";", 
     " ", 
     RowBox[{"(*", 
      RowBox[{"dummy", " ", "positions", " ", "created"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"rdn", "=", 
      RowBox[{"computeDummy", "[", 
       RowBox[{"ran", ",", "rbn", ",", "rcn", ",", "lBond"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Matr", "=", 
      RowBox[{"Quiet", "[", 
       RowBox[{
        RowBox[{"RotationMatrix", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"ran", "-", "rdn"}], ",", 
           RowBox[{"rdo", "-", "rao"}]}], "}"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"RotationMatrix", "::", "spln"}], "}"}]}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "A", " ", "matrix", " ", "that", " ", "rotates", " ", "vector", " ", 
       "1", 
       RowBox[{"(", 
        RowBox[{"Vad", " ", "new"}], ")"}], " ", "to", " ", "the", " ", 
       "direction", " ", "of", " ", "vector", " ", "2", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Vda", " ", "old"}], ")"}], "."}]}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"movedMon", "=", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"rao", "+", 
          RowBox[{"Matr", ".", 
           RowBox[{"(", 
            RowBox[{"#", "-", "rdn"}], ")"}]}]}], "&"}], "/@", "newPos"}], 
       ")"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "New", " ", "monomer", " ", "is", " ", "aligned", " ", "by", " ", 
       "dotting", " ", "with", " ", "matrix", " ", "then", " ", "moved", " ", 
       "into", " ", "place", " ", "next", " ", "to", " ", "rao"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ran", ",", "rbn", ",", "rcn"}], "}"}], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"movedMon", "[", 
         RowBox[{"[", "an", "]"}], "]"}], ",", 
        RowBox[{"movedMon", "[", 
         RowBox[{"[", "bn", "]"}], "]"}], ",", 
        RowBox[{"movedMon", "[", 
         RowBox[{"[", "cn", "]"}], "]"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dih", "=", 
      RowBox[{"DihedralAngle", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"ran", ",", "rao"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"rbn", "-", "ran"}], ")"}], ",", 
          RowBox[{"(", 
           RowBox[{"rbo", "-", "rao"}], ")"}]}], "}"}]}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "Calculate", " ", "existing", " ", "dihedral", " ", "angle", " ", 
        "between", " ", "b"}], "-", 
       RowBox[{"a", " ", 
        RowBox[{"vectors", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"Matr2", "=", 
      RowBox[{"RotationMatrix", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"-", "phi"}], " ", "Degree"}], "+", "dih"}], ",", 
        RowBox[{"(", 
         RowBox[{"ran", "-", "rao"}], ")"}]}], "]"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{
      "A", " ", "matrix", " ", "that", " ", "rotates", " ", "around", " ", 
       "the", " ", "connecting", " ", "atoms", " ", "vector", " ", "by", " ", 
       "specified", " ", "dih", " ", "angle"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"rao", "+", 
         RowBox[{"Matr2", ".", 
          RowBox[{"(", 
           RowBox[{"#", "-", "rao"}], ")"}]}]}], "&"}], "/@", "movedMon"}], 
      ")"}]}]}], " ", 
   RowBox[{"(*", 
    RowBox[{
    "New", " ", "monomer", " ", "is", " ", "rotated", " ", "around", " ", 
     "bond", " ", "axis", " ", "by", " ", "dotting", " ", "with", " ", 
     "matrix2"}], "*)"}], "]"}]}]], "Input",
