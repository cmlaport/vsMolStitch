Cell["\<\
After placing monomers, you can rotate the backbone to a specific direction. \
Atoms 1 and 0 create a vector along the polymer. The vector is the direction \
we wish to align to, r0 is a reference atom when writing out the new \
coordinates.\
\>", "Text",
 CellChangeTimes->{{3.933329735243894*^9, 3.9333298709657173`*^9}, {
   3.984496134612862*^9, 3.9844961658211*^9}, {3.984496269813758*^9, 
   3.984496308867103*^9}, 3.984496340671216*^9, {3.9844963793936987`*^9, 
   3.984496411954155*^9}},ExpressionUUID->"0a652de6-5751-4864-a69b-\
fb5d74a89ea9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rotateMol", "[", 
   RowBox[{"atom1_", ",", "atom0_", ",", "vector_", ",", 
    RowBox[{"r0_", ":", 
     RowBox[{"-", "1"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"current", ",", "Matr", ",", "rback"}], " ", "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"current", "=", " ", 
      RowBox[{
       RowBox[{"atomXYZ", "[", 
        RowBox[{"[", "atom1", "]"}], "]"}], " ", "-", " ", 
       RowBox[{"atomXYZ", "[", 
        RowBox[{"[", "atom0", "]"}], "]"}]}]}], ";", "\n", 
     RowBox[{"Matr", " ", "=", " ", 
      RowBox[{"RotationMatrix", "[", 
       RowBox[{"{", 
        RowBox[{"current", ",", " ", "vector"}], "}"}], "]"}]}], ";", "\n", 
     RowBox[{"rback", " ", "=", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"Matr", " ", ".", " ", 
          RowBox[{"(", 
           RowBox[{"#", " ", "-", " ", 
            RowBox[{"atomXYZ", "[", 
             RowBox[{"[", "r0", "]"}], "]"}]}], ")"}]}], " ", "&"}], " ", "/@",
         " ", "atomXYZ"}], ")"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"atomXYZ", " ", "=", " ", "rback"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{
  3.9844955831992826`*^9, {3.984495738387616*^9, 3.98449577191641*^9}, 
   3.984495885352771*^9},
 CellLabel->
  "In[547]:=",ExpressionUUID->"f6551df3-dd84-4cef-b572-1496a0d764cc"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Output", "Section",
 CellChangeTimes->{{3.984479510833747*^9, 
  3.984479511814563*^9}},ExpressionUUID->"33ce8bab-6079-42f5-bcd1-\
f028429d364c"],

Cell["\<\
Getting a, b, c order correct for adding monomers can be confusing, \
visualizing the structure with colored spheres according to the elements\
\>", "Text",
 CellChangeTimes->{{3.9844795251553793`*^9, 
  3.984479533284369*^9}},ExpressionUUID->"345621f5-72c2-4c99-8356-\
21875f157294"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"colornames", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"elements", "/.", 
         RowBox[{"\"\<Cl\>\"", "->", "Green"}]}], "/.", 
        RowBox[{"\"\<C\>\"", "->", "Gray"}]}], "/.", 
       RowBox[{"\"\<S\>\"", "->", "Yellow"}]}], "/.", 
      RowBox[{"\"\<N\>\"", "->", "Blue"}]}], "/.", 
     RowBox[{"\"\<F\>\"", "->", "Cyan"}]}], "/.", 
    RowBox[{"\"\<O\>\"", "->", "Red"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Graphics3D", "[", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Hue", "[", 
       RowBox[{"colornames", "[", 
        RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
      RowBox[{"Sphere", "[", 
       RowBox[{
        RowBox[{"atomXYZ", "[", 
         RowBox[{"[", "i", "]"}], "]"}], ",", "0.09"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "1", ",", 
      RowBox[{"Length", "[", "atomXYZ", "]"}]}], "}"}]}], "]"}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.884188716325144*^9, 3.884188737163272*^9}, {
