Cell["\<\
computeDist is an \[OpenCurlyDoubleQuote]on the fly\[CloseCurlyDoubleQuote] \
function that calculates distances between the 2 atoms to be used in stiff \
ring constraints.
Requires a pdb table and the serial numbers of two atoms in the monomer itp \
file. Outputs the distance. This can be added to a monomer itp file.\
\>", "CodeText",
 CellChangeTimes->{{3.882527792777874*^9, 3.8825278034870367`*^9}, {
  3.883230481243487*^9, 3.8832305128198338`*^9}, {3.883236193124132*^9, 
  3.883236196107925*^9}, {3.883236287487925*^9, 3.883236290795232*^9}, {
  3.8832365396190243`*^9, 3.883236609469232*^9}, {3.8832368794079638`*^9, 
  3.883236914622059*^9}, {3.883236962498884*^9, 3.8832370250139723`*^9}, {
  3.8832370796326857`*^9, 3.883237159706991*^9}, {3.883761409506401*^9, 
  3.883761455431304*^9}, {3.8853876132409983`*^9, 
  3.885387614242712*^9}},ExpressionUUID->"cd472846-3154-4f32-8d6b-\
e13ac8f2f2c9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"computeDist", "[", 
   RowBox[{"monpdb_", ",", "a_", ",", "b_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"posns", ",", "aPos", ",", "bPos"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"posns", "=", 
      RowBox[{
       RowBox[{"getPDBInfo", "[", "monpdb", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"aPos", "=", 
      RowBox[{"posns", "[", 
       RowBox[{"[", "a", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"bPos", "=", 
      RowBox[{"posns", "[", 
       RowBox[{"[", "b", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Norm", "[", 
      RowBox[{"aPos", "-", "bPos"}], "]"}]}]}], "]"}]}]], "Input",
