         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "==", "\"\<HETATM\>\""}], ")"}], 
          "&"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"6", ";;", "8"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"posns", "=", 
      RowBox[{"posns", "/", "10"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"anames", "=", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{"mpdb", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "==", "\"\<HETATM\>\""}], ")"}], 
          "&"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "3"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"conects", "=", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{"mpdb", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "==", "\"\<CONECT\>\""}], ")"}], 
          "&"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"2", ";;"}]}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"resnames", "=", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{"mpdb", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "==", "\"\<HETATM\>\""}], ")"}], 
          "&"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "4"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"species", "=", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{"mpdb", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "==", "\"\<HETATM\>\""}], ")"}], 
          "&"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "9"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
      "posns", ",", "anames", ",", "conects", ",", "resnames", ",", 
       "species"}], "}"}]}]}], "]"}]}]], "Input",
