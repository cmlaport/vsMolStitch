   RowBox[{"posns_", ",", "anames_", ",", "resnames_", ",", "species_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"atomXYZ", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"atomXYZ", ",", "posns"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"atomName", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"atomName", ",", "anames"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"resName", "=", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"resName", ",", "resnames"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"elements", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"elements", ",", "species"}], "]"}]}], ";"}]}], 
   "]"}]}]], "Input",
