Cell["\<\
addNextMonomer uses movemonomer to calculate the coordinates of a new monomer \
based on the coordinates of a polymer residue (called by residue number). \
Then it saves the monomer itp and pdb information to global lists, using the \
residue and serial number offsets as needed.
Required inputs: 
monomer pdb file, monomer itp file, input as a table. The residue number of \
the existing polymer residue that we want to connect to.
The a, b,c line numbers of the monomer coordinates list. the a,b,c line \
numbers for the polymer coordinates. a is the connecting atom. b is a \
flanking atom used in calculating the dihedral angle, c is the other flanking \
atom for a stiff membered ring. lbond is the bond length, phi is the dihedral \
angle.\
\>", "CodeText",
 CellChangeTimes->{{3.883748759197349*^9, 3.883748821278458*^9}, {
   3.8837488731735477`*^9, 3.883748908386943*^9}, {3.883748950306953*^9, 
   3.883749244693912*^9}, 3.884276223723982*^9, {3.9844889266173143`*^9, 
   3.98448892736126*^9}},ExpressionUUID->"c214b58e-d0b6-4ba0-8912-\
15a8a5155466"],

Cell[BoxData[
 RowBox[{
  RowBox[{"addNextMonomer", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"newpdb_", ",", "newitp_"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"an_", ",", "bn_", ",", "cn_"}], "}"}], ",", "Ores_", ",", 
    RowBox[{"{", 
     RowBox[{"ao_", ",", "bo_", ",", "co_"}], "}"}], ",", "lBond_", ",", 
    RowBox[{"phi_", ":", "180.0"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "posns", ",", "anames", ",", "conects", ",", "resnames", ",", "species", 
      ",", "movedMon"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "posns", ",", "anames", ",", "conects", ",", "resnames", ",", 
        "species"}], "}"}], "=", 
      RowBox[{"getPDBInfo", "[", "newpdb", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"movedMon", "=", 
      RowBox[{"moveMonomer", "[", 
       RowBox[{
       "posns", ",", "Ores", ",", "an", ",", "bn", ",", "cn", ",", "ao", ",", 
        "bo", ",", "co", ",", "lBond", ",", "phi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"saveAtomInfo", "[", 
      RowBox[{"movedMon", ",", "anames", ",", "resnames", ",", "species"}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"chemBonds", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"chemBonds", ",", 
        RowBox[{"conects", "+", 
         RowBox[{"offset", "[", 
          RowBox[{"[", 
           RowBox[{"-", "1"}], "]"}], "]"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"saveITPInfo", "[", "newitp", "]"}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"nMon", "=", 
      RowBox[{"nMon", "+", "1"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"offset", ",", 
       RowBox[{
        RowBox[{"offset", "[", 
         RowBox[{"[", 
          RowBox[{"-", "1"}], "]"}], "]"}], "+", 
        RowBox[{"Length", "[", "anames", "]"}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"addToPotential", "[", 
      RowBox[{"nMon", ",", 
       RowBox[{"{", 
        RowBox[{"an", ",", "bn", ",", "cn"}], "}"}], ",", "Ores", ",", 
       RowBox[{"{", 
        RowBox[{"ao", ",", "bo", ",", "co"}], "}"}]}], "]"}], ";"}]}], 
   "]"}]}]], "Input",
